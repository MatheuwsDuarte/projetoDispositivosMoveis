<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     ARQUIVO: app/src/main/res/layout/activity_main.xml
     CoordinatorLayout: pai "inteligente" que coordena animações
     entre os filhos (ex: FAB sobe quando Snackbar aparece).
     ============================================================ -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- AppBar com Toolbar no topo -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:title="Data &amp; Logic Vault"
            android:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- RecyclerView: a lista de Trilhas.
         app:layout_behavior: diz ao RecyclerView para descer
         automaticamente abaixo da AppBar. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTrilhas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Texto exibido quando a lista está vazia -->
    <TextView
        android:id="@+id/textViewVazio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Nenhuma trilha ainda.\nToque em + para começar!"
        android:textAlignment="center"
        android:textColor="@android:color/darker_gray"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- FAB: botão flutuante no canto inferior direito.
         layout_anchor + layout_anchorGravity: ancora o FAB
         ao CoordinatorLayout no canto inferior direito. -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdicionarTrilha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Adicionar Trilha"
        android:src="@android:drawable/ic_input_add"
        app:tint="@android:color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>